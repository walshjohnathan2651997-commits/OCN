{
  "name": "pdf_sentence_corpus",
  "version": "1.0.0",
  "description": "Sentence-level PDF corpus units used as the BM25 retrieval pool. One JSON object per line in sentences.jsonl. Sibling files pages.jsonl and blocks.jsonl share the same hash/redaction conventions.",
  "file_format": "jsonl",
  "primary_file": "sentences.jsonl",
  "sibling_files": [
    "pages.jsonl",
    "blocks.jsonl"
  ],
  "required_columns": [
    "paper_id",
    "pdf_filename",
    "pdf_sha256",
    "page_number",
    "block_id",
    "sentence_id",
    "unit_id",
    "raw_text",
    "clean_text",
    "raw_text_sha256",
    "clean_text_sha256",
    "n_chars",
    "n_words",
    "section_hint"
  ],
  "optional_columns": [],
  "forbidden_columns_for_public_release": [
    "raw_text",
    "clean_text",
    "raw_page_text",
    "clean_page_text",
    "raw_block_text",
    "clean_block_text"
  ],
  "forbidden_columns_for_scoring": [],
  "hash_columns": [
    "pdf_sha256",
    "raw_text_sha256",
    "clean_text_sha256"
  ],
  "text_columns": [
    "raw_text",
    "clean_text"
  ],
  "redaction_required": true
}
